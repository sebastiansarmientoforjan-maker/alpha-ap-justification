# ============================================
# AP Math Justification - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git


# ============================================
# FIREBASE CONFIGURATION (REQUIRED)
# ============================================
# Get these from Firebase Console: https://console.firebase.google.com
# Project Settings > General > Your apps > SDK setup and configuration

# Firebase Client Config (Public - safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (Private - server-side only)
# Get from: Project Settings > Service Accounts > Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CLIENT_EMAIL=


# ============================================
# CLAUDE API (REQUIRED)
# ============================================
# For Socratic feedback and problem generation
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# ============================================
# DATA ADAPTER CONFIGURATION
# ============================================
# Which data service to use
# Options: 'firebase' | 'timeback' | 'mock'
DATA_ADAPTER=firebase


# ============================================
# TIMEBACK INTEGRATION (FUTURE - NOT YET IMPLEMENTED)
# ============================================
# TimeBack OAuth2 Configuration
# TIMEBACK_CLIENT_ID=
# TIMEBACK_CLIENT_SECRET=
# TIMEBACK_REDIRECT_URI=https://your-domain.com/api/auth/callback/timeback

# TimeBack API Endpoints
# TIMEBACK_ONEROSTER_BASE=https://api.alpha-1edtech.ai/ims/oneroster/rostering/v1p2
# TIMEBACK_GRADEBOOK_BASE=https://api.alpha-1edtech.ai/ims/oneroster/gradebook/v1p2
# TIMEBACK_QTI_BASE=https://qti.alpha-1edtech.ai/api

# TimeBack Cognito (OAuth2 Authorization Server)
# TIMEBACK_AUTH_URL=https://prod-beyond-timeback-api-2-idp.auth.us-east-1.amazoncognito.com
# TIMEBACK_TOKEN_URL=https://prod-beyond-timeback-api-2-idp.auth.us-east-1.amazoncognito.com/oauth2/token


# ============================================
# NEXT.JS CONFIGURATION
# ============================================
# Required for production deployments
# Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET=

# Your production domain
# NEXTAUTH_URL=https://your-domain.com

# Node environment
# NODE_ENV=development


# ============================================
# OPTIONAL: DEVELOPMENT OVERRIDES
# ============================================
# Disable authentication in development (use mock)
# DEV_DISABLE_AUTH=false

# Enable verbose logging
# DEBUG=true


# ============================================
# NOTES
# ============================================
# - Never commit this file with real values
# - Use .env.local for local development
# - Use Vercel environment variables for production
# - Keep FIREBASE_ADMIN_PRIVATE_KEY secure (server-side only)
# - ANTHROPIC_API_KEY should never be exposed to client
