# PDF Compiler Service Configuration

# API Key for authentication (generate with: openssl rand -base64 32)
PDF_COMPILER_API_KEY=your_secure_api_key_here

# Port (Railway will override this)
PORT=3001

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://your-nextjs-app.vercel.app,http://localhost:3000
